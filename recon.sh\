# -------- SMART DETECTION ----------
is_ip() {
[[ $1 =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]
}

# -------- SCAN ENGINE ----------
scan_target() {
target=$1
timestamp=$(date +"%Y-%m-%d_%H-%M-%S")
dir="results/$target-$timestamp"
mkdir -p "$dir"

echo -e "\n${GREEN}[+] Target: $target${NC}"

if is_ip "$target"; then
    echo -e "${CYAN}[i] Input Detected: IP Address${NC}"

    echo -e "${BLUE}[+] Finding Domains & Subdomains from IP...${NC}"
    echo "$target" | dnsx -ptr -silent > $dir/domains.txt 2>/dev/null
    echo "$target" | hakrevdns -d > $dir/domains.txt 2>/dev/null

    echo -e "${BLUE}[+] Running Nmap...${NC}"
    nmap -A -T4 $target > $dir/nmap.txt

    echo -e "${BLUE}[+] Whois Lookup...${NC}"
    whois $target > $dir/whois.txt

    echo "$target" > $dir/ip.txt

else
    echo -e "${CYAN}[i] Input Detected: Domain / Subdomain${NC}"

    echo -e "${BLUE}[+] Resolving IP Address...${NC}"
    dig +short $target > $dir/ip.txt

    echo -e "${BLUE}[+] Finding Subdomains...${NC}"
    subfinder -d $target -silent > $dir/domains.txt
    amass enum -passive -d $target >> $dir/domains.txt

    echo -e "${BLUE}[+] Pinging Target...${NC}"
    ping -c 3 $target > $dir/ping.txt

    echo -e "${BLUE}[+] Running Nmap...${NC}"
    nmap -A -T4 $target > $dir/nmap.txt

    echo -e "${BLUE}[+] Whois Lookup...${NC}"
    whois $target > $dir/whois.txt

    echo -e "${BLUE}[+] DNS Enumeration...${NC}"
    dnsenum $target > $dir/dnsenum.txt
fi

generate_html $target $dir

echo -e "${GREEN}[✔] Scan Complete${NC}"
echo -e "${CYAN}Report: $dir/report.html${NC}"
}

